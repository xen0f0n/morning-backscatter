<!DOCTYPE html>
<html lang="{{ site.language | default('en') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{{ site.title }}</title>
  <meta name="description" content="{{ site.tagline }}" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.baseUrl }}/rss.xml" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ site.title }}" />
  <meta property="og:description" content="{{ site.tagline }}" />
  <meta property="og:url" content="{{ site.baseUrl }}/" />
  <meta property="og:image" content="{{ site.baseUrl }}/assets/og/home.png" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ site.title }}" />
  <meta name="twitter:description" content="{{ site.tagline }}" />
  <meta name="twitter:image" content="{{ site.baseUrl }}/assets/og/home.png" />

  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500&f[]=general-sans@500,600&display=swap"
    rel="stylesheet">

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Satoshi', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            ui: ['General Sans', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            mono: ['ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', 'Liberation Mono', 'Courier New', 'monospace'],
          },
          colors: {
            space: '#0B0C10',
            paper: '#F8FAFC'
          }
        }
      }
    }
  </script>

  <style>
    [x-cloak] {
      display: none !important;
    }

    :focus-visible {
      outline: 2px solid rgba(52, 211, 153, 0.9);
      outline-offset: 3px;
    }
  </style>
  
  {% include "partials/analytics.html.j2" %}

  <script>
    function initialThemeIsDark() {
      const stored = localStorage.getItem('mb_theme');
      if (stored === 'dark') return true;
      if (stored === 'light') return false;
      return false;
    }

    function themeApp() {
      return {
        darkMode: false,

        init() {
          this.darkMode = initialThemeIsDark();
          document.documentElement.classList.toggle('dark', this.darkMode);
        },

        toggleTheme() {
          this.darkMode = !this.darkMode;
          document.documentElement.classList.toggle('dark', this.darkMode);

          try {
            localStorage.setItem('mb_theme', this.darkMode ? 'dark' : 'light');
          } catch (e) { }
        }
      };
    }
  </script>
</head>

<body
  x-data="themeApp()"
  x-init="init()"
  x-cloak
  :class="darkMode ? 'bg-space text-white' : 'bg-slate-50 text-slate-950'"
  class="min-h-screen p-6 transition-colors duration-300"
>
  <main class="max-w-3xl mx-auto py-16">

    <header class="flex items-start justify-between gap-4">
      <div>
        <h1
          class="text-4xl font-black tracking-tighter transition-colors"
          :class="darkMode ? 'bg-clip-text text-transparent bg-gradient-to-r from-sky-400 via-emerald-400 to-teal-300' : 'text-slate-950'"
        >
          {{ site.title }}
        </h1>
        <p
          class="mt-2"
          :class="darkMode ? 'text-slate-300' : 'text-slate-600'"
        >
          {{ site.tagline }}
        </p>
      </div>

    <button
      @click="toggleTheme()"
      type="button"
      class="w-11 h-11 p-0 aspect-square rounded-full border transition-all hover:scale-105 shrink-0 flex items-center justify-center leading-none"
      :class="darkMode ? 'border-white/20 bg-white/5 hover:bg-white/10' : 'border-slate-300 bg-white shadow-sm'"
      aria-label="Toggle theme"
    >
      <span x-show="darkMode" class="text-yellow-300 text-lg leading-none">☀</span>
      <span x-show="!darkMode" class="text-slate-700 text-lg leading-none">☾</span>
    </button>
    </header>

    {% if latest %}
      <a
        href="{{ latest.path }}"
        class="block mt-10 rounded-3xl border p-6 transition-all duration-300"
        :class="darkMode ? 'bg-white/5 border-white/10 hover:border-emerald-400/40 hover:bg-white/10' : 'bg-white border-slate-200 shadow-sm hover:shadow-md'"
      >
      <div class="text-xs uppercase tracking-widest text-emerald-500">Latest issue</div>
      <h2 class="mt-2 text-2xl font-bold">Issue #{{ "%03d"|format(latest.issueNo) }}</h2>
      <p
        class="mt-2"
        :class="darkMode ? 'text-slate-300' : 'text-slate-600'"
      >
        {{ latest.pulse.title }} · {{ latest.quicklook.title }} · {{ latest.coherence.title }}
      </p>
    </a>
    {% endif %}

    {% if issues %}
  <section class="mt-8">
    <h2
      class="text-xs uppercase tracking-widest font-bold"
      :class="darkMode ? 'text-slate-400' : 'text-slate-500'"
    >
      All issues
    </h2>

    <div class="mt-3 space-y-3">
      {% for item in issues[1:] %}
        <a
          href="{{ item.path }}"
          class="block rounded-2xl border p-4 transition-all duration-300"
          :class="darkMode ? 'bg-white/5 border-white/10 hover:border-emerald-400/40 hover:bg-white/10' : 'bg-white border-slate-200 shadow-sm hover:shadow-md'"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="text-sm font-bold">
                Issue #{{ "%03d"|format(item.issueNo) }}
              </div>

              <p
                class="mt-1 text-sm leading-relaxed"
                :class="darkMode ? 'text-slate-300' : 'text-slate-600'"
              >
                {{ item.pulse.title }} · {{ item.quicklook.title }} · {{ item.coherence.title }}
              </p>
            </div>

            <span
              class="text-xs font-bold shrink-0"
              :class="darkMode ? 'text-emerald-300' : 'text-emerald-600'"
            >
              Open →
            </span>
          </div>
        </a>
      {% endfor %}
    </div>
  </section>
{% endif %}

    <div
      class="mt-8 flex gap-4 text-sm"
      :class="darkMode ? 'text-slate-300' : 'text-slate-700'"
    >
    <a
      class="underline underline-offset-4 hover:opacity-80"
      href="{{ site.baseUrl }}/rss.xml"
      target="_blank"
      rel="noopener noreferrer"
    >
      RSS
    </a>

    <a
      class="underline underline-offset-4 hover:opacity-80"
      href="{{ site.bylineUrl }}"
      target="_blank"
      rel="noopener noreferrer"
    >
      Spectral Reflectance
    </a>
    </div>

  </main>
</body>
</html>